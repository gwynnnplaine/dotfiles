# --- Appearance ---
theme = light:Rose Pine Dawn,dark:Rose Pine
font-family = "Iosevka Nerd Font Mono"
font-size = 20
font-feature = -liga
cursor-style = block
cursor-style-blink = true
adjust-cell-height = 15%

# macOS specific
# Static window title (overrides the dynamic dir/command title from shell-integration).
title = ghostty
macos-titlebar-style = transparent
macos-option-as-alt = left
window-padding-x = 0
window-padding-y = 0
window-width = 90
window-height = 30
window-padding-balance = true
window-decoration = true
window-colorspace = display-p3
window-save-state = always

# Background
background-opacity = 1

# Split panes
unfocused-split-opacity = 0.85
split-divider-color = #4b4b4b

# --- Functionality ---
copy-on-select = false
mouse-scroll-multiplier = 0.4
clipboard-read = allow
clipboard-write = allow

# Bleeding-edge Ghostty builds (tip channel; less stable than stable)
auto-update-channel = tip

# Ensure the window stays open if a command fails
confirm-close-surface = false

# --- Keybinds ---
# Use Option + Arrow keys to navigate splits
keybind = alt+left=goto_split:left
keybind = alt+right=goto_split:right
keybind = alt+up=goto_split:up
keybind = alt+down=goto_split:down

# Zoom a split (equivalent to tmux zoom) for deep coding
keybind = cmd+enter=toggle_split_zoom

# Send Ctrl+S through to the terminal (e.g. Neovim :w) instead of XOFF flow-control
keybind = ctrl+s=text:\x13

# Floating quake-style quick terminal
keybind = global:ctrl+minus=toggle_quick_terminal
# Global show/hide the Ghostty window (iTerm2-style)
keybind = global:ctrl+equal=toggle_visibility

