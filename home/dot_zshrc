# ~/.zshrc — minimal POSIX bootstrap.
# zsh sets up the environment, then hands off to Nushell for interactive use.
# Daily shell is Nushell (~/.config/nushell). Escape to plain zsh: NU_LAUNCHED=1 zsh

# --- PATH ---
export PATH="/usr/local/bin:/opt/homebrew/bin:$HOME/bin:$PATH"

export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# GNU coreutils (findutils/getopt/make/util-linux) ahead of BSD versions
BREW_PREFIX="$(brew --prefix)"
export PATH="$BREW_PREFIX/opt/findutils/libexec/gnubin:$BREW_PREFIX/opt/gnu-getopt/bin:$BREW_PREFIX/opt/make/libexec/gnubin:$BREW_PREFIX/opt/util-linux/bin:$PATH"

export PATH="$PATH:$HOME/.local/bin"

# --- Environment ---
export LC_ALL=en_US.UTF-8
export SOPS_AGE_KEY_FILE=~/.config/sops/age/keys.txt
export AGE_KEY_FILE=~/.config/sops/age/keys.txt

# --- Hand off to Nushell for interactive use ---
if [[ -o interactive && -z "$NU_LAUNCHED" && "$TERM" != "dumb" ]] && command -v nu >/dev/null 2>&1; then
  export NU_LAUNCHED=1
  exec nu
fi
