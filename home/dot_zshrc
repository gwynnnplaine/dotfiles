# --- 1. Environment Paths ---
# Ensure Homebrew and user binaries are prioritized
export PATH="/usr/local/bin:/opt/homebrew/bin:$HOME/bin:$PATH"
export PATH="$PATH:/Library/Frameworks/Python.framework/Versions/3.8/bin"

# Path to your oh-my-zsh installation
export ZSH="$HOME/.oh-my-zsh"

# --- 2. Secrets & Keys ---
export SOPS_AGE_KEY_FILE=~/.config/sops/age/keys.txt
export AGE_KEY_FILE=~/.config/sops/age/keys.txt

# --- 3. Oh My Zsh Setup ---
# Note: We leave ZSH_THEME empty because we are using Starship
ZSH_THEME=""

# Active plugins
plugins=(
  git 
  zoxide 
  fzf 
  gh 
  brew 
  zsh-syntax-highlighting 
  zsh-autosuggestions
)

source $ZSH/oh-my-zsh.sh

# --- 4. Modern Tool Aliases ---
# Replace legacy commands with Rust-based versions
alias ls="eza --icons --group-directories-first"
alias ll="eza -lh --icons --grid --group-directories-first"
alias cat="bat"
alias grep="rg"
alias top="btop"

# --- 5. Tool Initializations ---
eval "$(starship init zsh)"
eval "$(zoxide init zsh)"

# Fix for Vim using the Option key as Alt
export LC_ALL=en_US.UTF-8

# Preview file content using 'bat' when using Ctrl+T
export FZF_CTRL_T_OPTS="
  --walker-skip .git,Library,node_modules
  --preview 'bat -n --color=always {}'
  --bind 'ctrl-/:change-preview-window(down|hidden|)'"

# Preview directory tree using 'eza' when using Option+C
export FZF_ALT_C_OPTS="
  --walker-skip .git,Library,node_modules
  --preview 'eza --tree --color=always {} | head -200'"

# Set up fzf key bindings and fuzzy completion
source <(fzf --zsh)

# If the above doesn't work, manually force the bindings:
bindkey '^R' fzf-history-widget
bindkey '^T' fzf-file-widget

# Using fd
export FZF_DEFAULT_COMMAND='fd --type f --strip-cwd-prefix --hidden --exclude .git --exclude Library'
export FZF_ALT_C_COMMAND='fd --type d --hidden --strip-cwd-prefix --exclude .git --exclude Library'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

alias dev='zellij --layout work'

export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

export NVM_DIR=~/.nvm
 [ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"

export PATH="$(brew --prefix)/opt/findutils/libexec/gnubin:$(brew --prefix)/opt/gnu-getopt/bin:$(brew --prefix)/opt/make/libexec/gnubin:$(brew --prefix)/opt/util-linux/bin:${PATH}"

export PATH="$PATH:/Users/gwynplaine/.local/bin"

# --- Hand off to Nushell for interactive use (zsh stays the POSIX login shell) ---
# zsh sets PATH/brew/nvm above, then we exec into Nu so it inherits the full env.
# Escape hatch to plain zsh:  NU_LAUNCHED=1 zsh
if [[ -o interactive && -z "$NU_LAUNCHED" && "$TERM" != "dumb" ]] && command -v nu >/dev/null 2>&1; then
  export NU_LAUNCHED=1
  exec nu
fi
